    skos:definition "Relates a design entity to its claimed functions, affordances, quality attributes, constraints, or capabilities."@en ;
    skos:prefLabel "has capacity specification"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "required" .

dsr:hasEvaluation a owl:ObjectProperty ;
    rdfs:label "has evaluation"@en ;
    dcterms:identifier "has_evaluation" ;
    rdfs:comment "Relates a DSR study to an evaluation activity or assessment."@en ;
    rdfs:domain dsr:DSRStudy ;
    rdfs:range dsr:Evaluation ;
    owl:inverseOf dsr:isEvaluationOfStudy ;
    skos:closeMatch dsrv:has-evaluation ;
    skos:definition "Relates a DSR study to an evaluation activity or assessment."@en ;
    skos:prefLabel "has evaluation"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "required" .

dsr:hasMakePlan a owl:ObjectProperty ;
    rdfs:label "has make plan"@en ;
    dcterms:identifier "has_make_plan" ;
    rdfs:comment "Relates a design entity to the plan for producing an artifact instance."@en ;
    rdfs:domain dsr:DesignEntity ;
    rdfs:range dsr:MakePlan ;
    owl:inverseOf dsr:isMakePlanFor ;
    skos:closeMatch dsrv:has-make-plan ;
    skos:definition "Relates a design entity to the plan for producing an artifact instance."@en ;
    skos:prefLabel "has make plan"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "required" .

dsr:hasProblemSpace a owl:ObjectProperty ;
    rdfs:label "has problem space"@en ;
    dcterms:identifier "has_problem_space" ;
    rdfs:comment "Relates a DSR study to its represented problem space."@en ;
    rdfs:domain dsr:DSRStudy ;
    rdfs:range dsr:ProblemSpace ;
    owl:inverseOf dsr:isProblemSpaceOf ;
    skos:closeMatch dsrv:has-problem-space ;
    skos:definition "Relates a DSR study to its represented problem space."@en ;
    skos:prefLabel "has problem space"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "required" .

dsr:hasReliabilityAssessment a owl:ObjectProperty ;
    rdfs:label "has reliability assessment"@en ;
    dcterms:identifier "has_reliability_assessment" ;
    rdfs:comment "Relates a DSR study to a synchronic or diachronic reliability assessment for artifact, method, measures, process, implementation, evaluator, or design knowledge."@en ;
    rdfs:domain dsr:DSRStudy ;
    rdfs:range dsr:ReliabilityAssessment ;
    owl:inverseOf dsr:isReliabilityAssessmentOf ;
    skos:closeMatch dsrv:has-reliability-assessment ;
    skos:definition "Relates a DSR study to a synchronic or diachronic reliability assessment for artifact, method, measures, process, implementation, evaluator, or design knowledge."@en ;
    skos:prefLabel "has reliability assessment"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "conditional" .

dsr:hasRequirement a owl:ObjectProperty ;
    rdfs:label "has requirement"@en ;
    dcterms:identifier "has_requirement" ;
    rdfs:comment "Relates a DSR study to an objective, functional requirement, nonfunctional requirement, meta-requirement, acceptance criterion, or evaluation criterion."@en ;
    rdfs:domain dsr:DSRStudy ;
    rdfs:range dsr:Requirement ;
    owl:inverseOf dsr:isRequirementOf ;
    skos:closeMatch dsrv:has-requirement ;
    skos:definition "Relates a DSR study to an objective, functional requirement, nonfunctional requirement, meta-requirement, acceptance criterion, or evaluation criterion."@en ;
    skos:prefLabel "has requirement"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "required" .

dsr:hasTransparencyTrace a owl:ObjectProperty ;
    rdfs:label "has transparency trace"@en ;
    dcterms:identifier "has_transparency_trace" ;
    rdfs:comment "Relates a DSR study to documentation traces for process, problem-space, solution-space, build, evaluation, and contribution transparency."@en ;
    rdfs:domain dsr:DSRStudy ;
    rdfs:range dsr:TransparencyTrace ;
    owl:inverseOf dsr:isTransparencyTraceOf ;
    skos:closeMatch dsrv:has-transparency-trace ;
    skos:definition "Relates a DSR study to documentation traces for process, problem-space, solution-space, build, evaluation, and contribution transparency."@en ;
    skos:prefLabel "has transparency trace"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "required" .

dsr:hasUsePlan a owl:ObjectProperty ;
    rdfs:label "has use plan"@en ;
    dcterms:identifier "has_use_plan" ;
    rdfs:comment "Relates a design entity to the plan for using an artifact instance in context."@en ;
    rdfs:domain dsr:DesignEntity ;
    rdfs:range dsr:UsePlan ;
    owl:inverseOf dsr:isUsePlanFor ;
    skos:closeMatch dsrv:has-use-plan ;
    skos:definition "Relates a design entity to the plan for using an artifact instance in context."@en ;
    skos:prefLabel "has use plan"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "required" .

dsr:hasValidityAssessment a owl:ObjectProperty ;
    rdfs:label "has validity assessment"@en ;
    dcterms:identifier "has_validity_assessment" ;
    rdfs:comment "Relates a DSR study to an assessment of semantic, problem, requirements, artifact, evaluation, internal, external, pragmatic, contribution, or ethical validity."@en ;
    rdfs:domain dsr:DSRStudy ;
    rdfs:range dsr:ValidityAssessment ;
    owl:inverseOf dsr:isValidityAssessmentOf ;
    skos:closeMatch dsrv:has-validity-assessment ;
    skos:definition "Relates a DSR study to an assessment of semantic, problem, requirements, artifact, evaluation, internal, external, pragmatic, contribution, or ethical validity."@en ;
    skos:prefLabel "has validity assessment"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "recommended" .

dsr:includesProblemClass a owl:ObjectProperty ;
    rdfs:label "includes problem class"@en ;
    dcterms:identifier "includes_problem_class" ;
    rdfs:comment "Relates a problem space to a generalized problem class represented within it."@en ;
    rdfs:domain dsr:ProblemSpace ;
    rdfs:range dsr:ProblemClass ;
    owl:inverseOf dsr:isProblemClassIn ;
    skos:closeMatch dsrv:includes-problem-class ;
    skos:definition "Relates a problem space to a generalized problem class represented within it."@en ;
    skos:prefLabel "includes problem class"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "required" .

dsr:includesProblemInstance a owl:ObjectProperty ;
    rdfs:label "includes problem instance"@en ;
    dcterms:identifier "includes_problem_instance" ;
    rdfs:comment "Relates a problem space to a situated problem instance represented within it."@en ;
    rdfs:domain dsr:ProblemSpace ;
    rdfs:range dsr:ProblemInstance ;
    owl:inverseOf dsr:isProblemInstanceIn ;
    skos:closeMatch dsrv:includes-problem-instance ;
    skos:definition "Relates a problem space to a situated problem instance represented within it."@en ;
    skos:prefLabel "includes problem instance"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "required" .

dsr:instantiatesDesignEntity a owl:ObjectProperty ;
    rdfs:label "instantiates design entity"@en ;
    dcterms:identifier "instantiates_design_entity" ;
    rdfs:comment "Relates a concrete artifact instantiation to the design entity or artifact universal it implements or instantiates."@en ;
    rdfs:domain dsr:ArtifactInstantiation ;
    rdfs:range dsr:DesignEntity ;
    owl:inverseOf dsr:isInstantiatedBy ;
    skos:closeMatch dsrv:instantiates-design-entity ;
    skos:definition "Relates a concrete artifact instantiation to the design entity or artifact universal it implements or instantiates."@en ;
    skos:prefLabel "instantiates design entity"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "conditional" .

dsr:occursInContext a owl:ObjectProperty ;
    rdfs:label "occurs in context"@en ;
    dcterms:identifier "occurs_in_context" ;
    rdfs:comment "Relates a DSR study to the organizational, social, technical, temporal, regulatory, or artifact-network context in which it occurs."@en ;
    rdfs:domain dsr:DSRStudy ;
    rdfs:range dsr:Context ;
    owl:inverseOf dsr:isContextForStudy ;
    skos:closeMatch dsrv:occurs-in-context ;
    skos:definition "Relates a DSR study to the organizational, social, technical, temporal, regulatory, or artifact-network context in which it occurs."@en ;
    skos:prefLabel "occurs in context"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "required" .

dsr:supportsDesignKnowledge a owl:ObjectProperty ;
    rdfs:label "supports design knowledge"@en ;
    dcterms:identifier "supports_design_knowledge" ;
    rdfs:comment "Relates evaluation evidence to the design knowledge it supports, constrains, or helps warrant."@en ;
    rdfs:domain dsr:EvaluationEvidence ;
    rdfs:range dsr:DesignKnowledge ;
    owl:inverseOf dsr:isSupportedByEvidence ;
    skos:closeMatch dsrv:supports-design-knowledge ;
    skos:definition "Relates evaluation evidence to the design knowledge it supports, constrains, or helps warrant."@en ;
    skos:prefLabel "supports design knowledge"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "required" .

dsr:DesignDecision a owl:Class ;
    rdfs:label "Design Decision"@en ;
    dcterms:identifier "design_decision" ;
    rdfs:comment "A traceable choice about artifact structure, function, process, requirement satisfaction, capacity, evaluation, implementation, or boundary condition."@en ;
    rdfs:subClassOf dsr:DSREntity ;
    skos:closeMatch dsrv:design-decision ;
    skos:definition "A traceable choice about artifact structure, function, process, requirement satisfaction, capacity, evaluation, implementation, or boundary condition."@en ;
    skos:prefLabel "Design Decision"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "recommended" .

dsr:EvaluationTarget a owl:Class ;
    rdfs:label "Evaluation Target"@en ;
    dcterms:identifier "evaluation_target" ;
    rdfs:comment "A design entity, artifact instantiation, use claim, or contribution claim that can be evaluated."@en ;
    rdfs:subClassOf dsr:DSREntity ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( dsr:DesignEntity dsr:ArtifactInstantiation dsr:UseClaim dsr:ContributionClaim ) ] ;
    skos:definition "A design entity, artifact instantiation, use claim, or contribution claim that can be evaluated."@en ;
    skos:prefLabel "Evaluation Target"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "required" .

dsr:Objective a owl:Class ;
    rdfs:label "Objective"@en ;
    dcterms:identifier "objective" ;
    rdfs:comment "A design, research, evaluation, use, make, or contribution objective that translates problem and input knowledge into an intended target."@en ;
    rdfs:subClassOf dsr:DesignSpecification ;
    skos:closeMatch dsrv:objective ;
    skos:definition "A design, research, evaluation, use, make, or contribution objective that translates problem and input knowledge into an intended target."@en ;
    skos:prefLabel "Objective"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "required" .

dsr:OutputKnowledge a owl:Class ;
    rdfs:label "Output Knowledge"@en ;
    dcterms:identifier "output_knowledge" ;
    rdfs:comment "Knowledge generated by the DSR study that updates the knowledge base, including artifact knowledge, design principles, theories, patterns, methods, taxonomies, requirements, and evaluation findings."@en ;
    rdfs:subClassOf dsr:KnowledgeBaseEntity ;
    skos:closeMatch dsrv:output-knowledge ;
    skos:definition "Knowledge generated by the DSR study that updates the knowledge base, including artifact knowledge, design principles, theories, patterns, methods, taxonomies, requirements, and evaluation findings."@en ;
    skos:prefLabel "Output Knowledge"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "required" .

dsr:Problem a owl:Class ;
    rdfs:label "Problem"@en ;
    dcterms:identifier "problem" ;
    rdfs:comment "A design-relevant need, deficiency, gap, opportunity, or wicked situation requiring artifact intervention and researchable or evaluable framing."@en ;
    rdfs:subClassOf dsr:DSREntity ;
    skos:closeMatch dsrv:problem ;
    skos:definition "A design-relevant need, deficiency, gap, opportunity, or wicked situation requiring artifact intervention and researchable or evaluable framing."@en ;
    skos:prefLabel "Problem"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "required" .

dsr:ReliabilityAssessment a owl:Class ;
    rdfs:label "Reliability Assessment"@en ;
    dcterms:identifier "reliability_assessment" ;
    rdfs:comment "A synchronic or diachronic reliability assessment for artifact, method, measure, evaluator, process, implementation, or design knowledge consistency."@en ;
    rdfs:subClassOf dsr:QualityAssessment ;
    skos:closeMatch dsrv:reliability-assessment ;
    skos:definition "A synchronic or diachronic reliability assessment for artifact, method, measure, evaluator, process, implementation, or design knowledge consistency."@en ;
    skos:prefLabel "Reliability Assessment"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:sourceAnchor "theory_synthesis:9.2.reliability_framework" ;
    dsr:status "conditional" .

dsr:ResearchProcessActivity a owl:Class ;
    rdfs:label "Research Process Activity"@en ;
    dcterms:identifier "research_process_activity" ;
    rdfs:comment "An activity performed in the DSR process, including construction, demonstration, evaluation, replication, communication, or review."@en ;
    rdfs:subClassOf dsr:DSREntity ;
    skos:closeMatch dsrv:research-process-activity ;
    skos:definition "An activity performed in the DSR process, including construction, demonstration, evaluation, replication, communication, or review."@en ;
    skos:prefLabel "Research Process Activity"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "recommended" .

dsr:ValidityAssessment a owl:Class ;
    rdfs:label "Validity Assessment"@en ;
    dcterms:identifier "validity_assessment" ;
    rdfs:comment "An assessment of semantic, problem, requirements, artifact, evaluation, internal, external, pragmatic, contribution, ethical, or responsible-design validity."@en ;
    rdfs:subClassOf dsr:QualityAssessment ;
    skos:closeMatch dsrv:validity-assessment ;
    skos:definition "An assessment of semantic, problem, requirements, artifact, evaluation, internal, external, pragmatic, contribution, ethical, or responsible-design validity."@en ;
    skos:prefLabel "Validity Assessment"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:sourceAnchor "theory_synthesis:9.1.validity_taxonomy" ;
    dsr:status "recommended" .

dsr:producesDesignEntity a owl:ObjectProperty ;
    rdfs:label "produces design entity"@en ;
    dcterms:identifier "produces_design_entity" ;
    rdfs:comment "Relates a DSR study to the abstract or reusable design entity, artifact kind, or artifact universal it produces."@en ;
    rdfs:domain dsr:DSRStudy ;
    rdfs:range dsr:DesignEntity ;
    owl:inverseOf dsr:isDesignEntityProducedBy ;
    skos:closeMatch dsrv:produces-design-entity ;
    skos:definition "Relates a DSR study to the abstract or reusable design entity, artifact kind, or artifact universal it produces."@en ;
    skos:prefLabel "produces design entity"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "required" .

dsr:usesInputKnowledge a owl:ObjectProperty ;
    rdfs:label "uses input knowledge"@en ;
    dcterms:identifier "uses_input_knowledge" ;
    rdfs:comment "Relates a DSR study to prior descriptive, prescriptive, theoretical, practitioner, artifact, methodological, or technical knowledge used for rigor grounding."@en ;
    rdfs:domain dsr:DSRStudy ;
    rdfs:range dsr:InputKnowledge ;
    owl:inverseOf dsr:isInputKnowledgeUsedBy ;
    skos:closeMatch dsrv:uses-input-knowledge ;
    skos:definition "Relates a DSR study to prior descriptive, prescriptive, theoretical, practitioner, artifact, methodological, or technical knowledge used for rigor grounding."@en ;
    skos:prefLabel "uses input knowledge"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "required" .

dsr:BoundaryCondition a owl:Class ;
    rdfs:label "Boundary Condition"@en ;
    dcterms:identifier "boundary_condition" ;
    rdfs:comment "A condition of context, use, stakeholder class, artifact network, domain, time, resource, governance, or environment that limits where a claim or design knowledge applies."@en ;
    rdfs:subClassOf dsr:DSREntity ;
    skos:closeMatch dsrv:boundary-condition ;
    skos:definition "A condition of context, use, stakeholder class, artifact network, domain, time, resource, governance, or environment that limits where a claim or design knowledge applies."@en ;
    skos:prefLabel "Boundary Condition"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:sourceAnchor "theory_synthesis:10.1.contribution_dimensions" ;
    dsr:status "required" .

dsr:CapacitySpecification a owl:Class ;
    rdfs:label "Capacity Specification"@en ;
    dcterms:identifier "capacity_specification" ;
    rdfs:comment "A specification of claimed artifact functions, affordances, constraints, quality attributes, or capabilities expected from a design entity."@en ;
    rdfs:subClassOf dsr:DesignSpecification ;
    skos:altLabel "affordance specification"@en,
        "capability specification"@en ;
    skos:closeMatch dsrv:capacity-specification ;
    skos:definition "A specification of claimed artifact functions, affordances, constraints, quality attributes, or capabilities expected from a design entity."@en ;
    skos:prefLabel "Capacity Specification"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:sourceAnchor "theory_synthesis:4.2.make_use_claim_structure" ;
    dsr:status "required" .

dsr:InputKnowledge a owl:Class ;
    rdfs:label "Input Knowledge"@en ;
    dcterms:identifier "input_knowledge" ;
    rdfs:comment "Prior descriptive, prescriptive, theoretical, practitioner, artifact, methodological, technological, or design-pattern knowledge used to ground design and evaluation."@en ;
    rdfs:subClassOf dsr:KnowledgeBaseEntity ;
    skos:altLabel "justificatory knowledge"@en,
        "knowledge base grounding"@en,
        "rigor base"@en ;
    skos:closeMatch dsrv:input-knowledge ;
    skos:definition "Prior descriptive, prescriptive, theoretical, practitioner, artifact, methodological, technological, or design-pattern knowledge used to ground design and evaluation."@en ;
    skos:prefLabel "Input Knowledge"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:sourceAnchor "operational_synthesis:2.minimum_dsr_record_architecture",
        "theory_synthesis:1.definitional_nucleus" ;
    dsr:status "required" .

dsr:KnowledgeBaseEntity a owl:Class ;
    rdfs:label "Knowledge Base Entity"@en ;
    dcterms:identifier "knowledge_base_entity" ;
    rdfs:comment "A knowledge object used as input to, or produced by, a DSR study."@en ;
    rdfs:subClassOf dsr:DSREntity ;
    skos:closeMatch dsrv:knowledge-base-entity ;
    skos:definition "A knowledge object used as input to, or produced by, a DSR study."@en ;
    skos:prefLabel "Knowledge Base Entity"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "recommended" .

dsr:MakePlan a owl:Class ;
    rdfs:label "Make Plan"@en ;
    dcterms:identifier "make_plan" ;
    rdfs:comment "A plan for producing an artifact instance, including procedure, build logic, resources, constraints, and conformance expectations."@en ;
    rdfs:subClassOf dsr:DesignSpecification ;
    skos:altLabel "build plan"@en,
        "construction plan"@en ;
    skos:closeMatch dsrv:make-plan ;
    skos:definition "A plan for producing an artifact instance, including procedure, build logic, resources, constraints, and conformance expectations."@en ;
    skos:prefLabel "Make Plan"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:sourceAnchor "theory_synthesis:4.2.make_use_claim_structure" ;
    dsr:status "required" .

dsr:StakeholderNeed a owl:Class ;
    rdfs:label "Stakeholder Need"@en ;
    dcterms:identifier "stakeholder_need" ;
    rdfs:comment "A need, goal, pain point, requirement source, or value concern articulated by or inferred for a stakeholder."@en ;
    rdfs:subClassOf dsr:DSREntity ;
    skos:closeMatch dsrv:stakeholder-need ;
    skos:definition "A need, goal, pain point, requirement source, or value concern articulated by or inferred for a stakeholder."@en ;
    skos:prefLabel "Stakeholder Need"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "required" .

dsr:UsePlan a owl:Class ;
    rdfs:label "Use Plan"@en ;
    dcterms:identifier "use_plan" ;
    rdfs:comment "A plan for using an artifact instance in context, including user roles, use steps, use conditions, intended effects, and artifact-network assumptions."@en ;
    rdfs:subClassOf dsr:DesignSpecification ;
    skos:altLabel "application plan"@en,
        "usage plan"@en ;
    skos:closeMatch dsrv:use-plan ;
    skos:definition "A plan for using an artifact instance in context, including user roles, use steps, use conditions, intended effects, and artifact-network assumptions."@en ;
    skos:prefLabel "Use Plan"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:sourceAnchor "theory_synthesis:4.2.make_use_claim_structure" ;
    dsr:status "required" .

dsr:Claim a owl:Class ;
    rdfs:label "Claim"@en ;
    dcterms:identifier "claim" ;
    rdfs:comment "A statement asserted by a DSR study that requires evidence, warrant, scope, and boundary conditions."@en ;
    rdfs:subClassOf dsr:DSREntity ;
    skos:closeMatch dsrv:claim ;
    skos:definition "A statement asserted by a DSR study that requires evidence, warrant, scope, and boundary conditions."@en ;
    skos:prefLabel "Claim"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "recommended" .

dsr:Demonstration a owl:Class ;
    rdfs:label "Demonstration"@en ;
    dcterms:identifier "demonstration" ;
    rdfs:comment "A use-case, scenario, prototype, pilot, proof-of-concept, or case-based showing of artifact feasibility or possible utility."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dsr:demonstratesArtifact ;
            owl:someValuesFrom dsr:ArtifactInstantiation ],
        dsr:ResearchProcessActivity ;
    skos:closeMatch dsrv:demonstration ;
    skos:definition "A use-case, scenario, prototype, pilot, proof-of-concept, or case-based showing of artifact feasibility or possible utility."@en ;
    skos:prefLabel "Demonstration"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:sourceAnchor "operational_synthesis:5.process_model" ;
    dsr:status "recommended" .

dsr:DesignSpecification a owl:Class ;
    rdfs:label "Design Specification"@en ;
    dcterms:identifier "design_specification" ;
    rdfs:comment "A specification of artifact construction, use, capacity, boundary, conformance, or design rationale."@en ;
    rdfs:subClassOf dsr:DSREntity ;
    skos:closeMatch dsrv:design-specification ;
    skos:definition "A specification of artifact construction, use, capacity, boundary, conformance, or design rationale."@en ;
    skos:prefLabel "Design Specification"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "recommended" .

dsr:Context a owl:Class ;
    rdfs:label "Context"@en ;
    dcterms:identifier "context" ;
    rdfs:comment "The organizational, social, technical, temporal, cultural, regulatory, resource, and artifact-network conditions under which a DSR artifact is designed, instantiated, evaluated, used, or expected to transfer."@en ;
    rdfs:subClassOf dsr:DSREntity ;
    skos:closeMatch dsrv:context ;
    skos:definition "The organizational, social, technical, temporal, cultural, regulatory, resource, and artifact-network conditions under which a DSR artifact is designed, instantiated, evaluated, used, or expected to transfer."@en ;
    skos:prefLabel "Context"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:sourceAnchor "theory_synthesis:3.1.ontological_layers" ;
    dsr:status "required" .

dsr:DocumentationArtifact a owl:Class ;
    rdfs:label "Documentation Artifact"@en ;
    dcterms:identifier "documentation_artifact" ;
    rdfs:comment "A record, log, trace, diagram, package, or report that makes the DSR study reviewable, reusable, auditable, or intelligible."@en ;
    rdfs:subClassOf dsr:DSREntity ;
    skos:closeMatch dsrv:documentation-artifact ;
    skos:definition "A record, log, trace, diagram, package, or report that makes the DSR study reviewable, reusable, auditable, or intelligible."@en ;
    skos:prefLabel "Documentation Artifact"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "recommended" .

dsr:ProblemClass a owl:Class ;
    rdfs:label "Problem Class"@en ;
    dcterms:identifier "problem_class" ;
    rdfs:comment "An abstract class of similar problems beyond the local case to which design knowledge may project or generalize."@en ;
    rdfs:subClassOf dsr:Problem ;
    skos:altLabel "abstract problem class"@en,
        "generalized problem frame"@en ;
    skos:closeMatch dsrv:problem-class ;
    skos:definition "An abstract class of similar problems beyond the local case to which design knowledge may project or generalize."@en ;
    skos:prefLabel "Problem Class"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:sourceAnchor "theory_synthesis:5.problem_space_theory" ;
    dsr:status "required" .

dsr:Stakeholder a owl:Class ;
    rdfs:label "Stakeholder"@en ;
    dcterms:identifier "stakeholder" ;
    rdfs:comment "An actor or group affected by, using, evaluating, sponsoring, governing, reviewing, or otherwise involved with the artifact, study, problem, evaluation, or design knowledge."@en ;
    rdfs:subClassOf dsr:DSREntity ;
    skos:closeMatch dsrv:stakeholder ;
    skos:definition "An actor or group affected by, using, evaluating, sponsoring, governing, reviewing, or otherwise involved with the artifact, study, problem, evaluation, or design knowledge."@en ;
    skos:prefLabel "Stakeholder"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:sourceAnchor "theory_synthesis:5.problem_space_theory" ;
    dsr:status "required" .

dsr:ContributionClaim a owl:Class ;
    rdfs:label "Contribution Claim"@en ;
    dcterms:identifier "contribution_claim" ;
    rdfs:comment "A claimed scientific, practical, methodological, design, or knowledge contribution made by the DSR study, including novelty, utility, evidence basis, audience, scope, and boundary conditions."@en ;
    rdfs:subClassOf dsr:Claim ;
    skos:altLabel "knowledge contribution claim"@en,
        "scientific contribution claim"@en ;
    skos:closeMatch dsrv:contribution-claim ;
    skos:definition "A claimed scientific, practical, methodological, design, or knowledge contribution made by the DSR study, including novelty, utility, evidence basis, audience, scope, and boundary conditions."@en ;
    skos:prefLabel "Contribution Claim"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:sourceAnchor "theory_synthesis:10.1.contribution_dimensions" ;
    dsr:status "required" .

dsr:DSRSpace a owl:Class ;
    rdfs:label "DSR Space"@en ;
    dcterms:identifier "dsr_space" ;
    rdfs:comment "An analytic space used to organize DSR documentation, such as problem, context, solution, design, artifact, evaluation, knowledge, or communication space."@en ;
    rdfs:subClassOf dsr:DSREntity ;
    skos:closeMatch dsrv:dsr-space ;
    skos:definition "An analytic space used to organize DSR documentation, such as problem, context, solution, design, artifact, evaluation, knowledge, or communication space."@en ;
    skos:prefLabel "DSR Space"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "recommended" .

dsr:ProblemInstance a owl:Class ;
    rdfs:label "Problem Instance"@en ;
    dcterms:identifier "problem_instance" ;
    rdfs:comment "A situated local occurrence of a problem in a specific environment, organization, practice, stakeholder group, or case."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dsr:abstractsToProblemClass ;
            owl:someValuesFrom dsr:ProblemClass ],
        dsr:Problem ;
    owl:disjointWith dsr:ProblemClass ;
    skos:altLabel "case problem"@en,
        "local problem"@en,
        "situated problem"@en ;
    skos:closeMatch dsrv:problem-instance ;
    skos:definition "A situated local occurrence of a problem in a specific environment, organization, practice, stakeholder group, or case."@en ;
    skos:prefLabel "Problem Instance"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:sourceAnchor "theory_synthesis:5.problem_space_theory" ;
    dsr:status "required" .

dsr:ProblemSpace a owl:Class ;
    rdfs:label "Problem Space"@en ;
    dcterms:identifier "problem_space" ;
    rdfs:comment "The represented domain of need, problem, gap, opportunity, deficiency, severity, feasibility, stakeholder significance, problem instance, and problem class."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dsr:includesProblemInstance ;
            owl:someValuesFrom dsr:ProblemInstance ],
        [ a owl:Restriction ;
            owl:onProperty dsr:includesProblemClass ;
            owl:someValuesFrom dsr:ProblemClass ],
        dsr:DSRSpace ;
    skos:closeMatch dsrv:problem-space ;
    skos:definition "The represented domain of need, problem, gap, opportunity, deficiency, severity, feasibility, stakeholder significance, problem instance, and problem class."@en ;
    skos:prefLabel "Problem Space"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:sourceAnchor "operational_synthesis:3.system_ontology",
        "theory_synthesis:3.1.ontological_layers" ;
    dsr:status "required" .

dsr:ArtifactInstantiation a owl:Class ;
    rdfs:label "Artifact Instantiation"@en ;
    dcterms:identifier "artifact_instantiation" ;
    rdfs:comment "A concrete implemented artifact, prototype, system, intervention, proof of concept, proof of value, or technical object used for demonstration or evaluation."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dsr:instantiatesDesignEntity ;
            owl:someValuesFrom dsr:DesignEntity ],
        dsr:DSREntity ;
    skos:altLabel "artifact instance"@en,
        "field implementation"@en,
        "implementation"@en,
        "proof of concept"@en,
        "prototype"@en,
        "technical object"@en ;
    skos:closeMatch dsrv:artifact-instantiation ;
    skos:definition "A concrete implemented artifact, prototype, system, intervention, proof of concept, proof of value, or technical object used for demonstration or evaluation."@en ;
    skos:prefLabel "Artifact Instantiation"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:sourceAnchor "operational_synthesis:4.artifact_operationalization",
        "theory_synthesis:4.1.artifact_ontology" ;
    dsr:status "conditional" .

dsr:Evaluation a owl:Class ;
    rdfs:label "Evaluation"@en ;
    dcterms:identifier "evaluation" ;
    rdfs:comment "An evidence-generating assessment of a design entity, artifact instantiation, use claim, contribution claim, design knowledge, or related DSR entity against explicit criteria."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dsr:generatesEvidence ;
            owl:someValuesFrom dsr:EvaluationEvidence ],
        [ a owl:Restriction ;
            owl:onProperty dsr:evaluates ;
            owl:someValuesFrom dsr:EvaluationTarget ],
        dsr:ResearchProcessActivity ;
    skos:closeMatch dsrv:evaluation ;
    skos:definition "An evidence-generating assessment of a design entity, artifact instantiation, use claim, contribution claim, design knowledge, or related DSR entity against explicit criteria."@en ;
    skos:prefLabel "Evaluation"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:sourceAnchor "operational_synthesis:6.evaluation_model",
        "theory_synthesis:8.evaluation_theory" ;
    dsr:status "required" .

dsr:Requirement a owl:Class ;
    rdfs:label "Requirement"@en ;
    dcterms:identifier "requirement" ;
    rdfs:comment "A functional, nonfunctional, meta-requirement, acceptance condition, or evaluation criterion derived from problem space, input knowledge, or stakeholder needs."@en ;
    rdfs:subClassOf dsr:DesignSpecification ;
    skos:closeMatch dsrv:requirement ;
    skos:definition "A functional, nonfunctional, meta-requirement, acceptance condition, or evaluation criterion derived from problem space, input knowledge, or stakeholder needs."@en ;
    skos:prefLabel "Requirement"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:sourceAnchor "operational_synthesis:2.minimum_dsr_record_architecture" ;
    dsr:status "required" .

dsr:EvaluationEvidence a owl:Class ;
    rdfs:label "Evaluation Evidence"@en ;
    dcterms:identifier "evaluation_evidence" ;
    rdfs:comment "Data, proof, expert review, experiment, simulation, field study, case, trace, analytic result, or other evidence generated or assembled to assess artifact, use, contribution, validity, reliability, or design knowledge claims."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dsr:supportsDesignKnowledge ;
            owl:someValuesFrom dsr:DesignKnowledge ],
        dsr:DSREntity ;
    owl:disjointWith dsr:ContributionClaim ;
    skos:altLabel "assessment evidence"@en,
        "evaluation data"@en,
        "validation evidence"@en ;
    skos:closeMatch dsrv:evaluation-evidence ;
    skos:definition "Data, proof, expert review, experiment, simulation, field study, case, trace, analytic result, or other evidence generated or assembled to assess artifact, use, contribution, validity, reliability, or design knowledge claims."@en ;
    skos:prefLabel "Evaluation Evidence"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:sourceAnchor "operational_synthesis:6.evaluation_model",
        "theory_synthesis:8.evaluation_theory" ;
    dsr:status "required" .

dsr:AntiPattern a owl:Class ;
    rdfs:label "Anti-Pattern"@en ;
    dcterms:identifier "anti_pattern" ;
    rdfs:comment "A known DSR failure mode, such as ex-post DSR-ification, routine design overclaim, artifact black box, weak problem grounding, weak solution grounding, evaluation mismatch, overlocalization, overabstraction, non-codified knowledge, transparency overload, or artifact maintenance neglect."@en ;
    rdfs:subClassOf dsr:DSREntity ;
    skos:closeMatch dsrv:anti-pattern ;
    skos:definition "A known DSR failure mode, such as ex-post DSR-ification, routine design overclaim, artifact black box, weak problem grounding, weak solution grounding, evaluation mismatch, overlocalization, overabstraction, non-codified knowledge, transparency overload, or artifact maintenance neglect."@en ;
    skos:prefLabel "Anti-Pattern"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:sourceAnchor "operational_synthesis:9.anti_pattern_checks" ;
    dsr:status "recommended" .

dsr:DesignKnowledge a owl:Class ;
    rdfs:label "Design Knowledge"@en ;
    dcterms:identifier "design_knowledge" ;
    rdfs:comment "Prescriptive means-end knowledge generated by the study, connecting problem and context conditions, artifact features, mechanisms or rationale, outcomes, evidence, and boundary conditions."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dsr:hasBoundaryCondition ;
            owl:someValuesFrom dsr:BoundaryCondition ],
        dsr:KnowledgeBaseEntity ;
    skos:altLabel "lambda knowledge"@en,
        "means-end knowledge"@en,
        "prescriptive design knowledge"@en ;
    skos:closeMatch dsrv:design-knowledge ;
    skos:definition "Prescriptive means-end knowledge generated by the study, connecting problem and context conditions, artifact features, mechanisms or rationale, outcomes, evidence, and boundary conditions."@en ;
    skos:prefLabel "Design Knowledge"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:sourceAnchor "theory_synthesis:6.1.design_knowledge_as_means_end_knowledge" ;
    dsr:status "required" .

dsr:TransparencyTrace a owl:Class ;
    rdfs:label "Transparency Trace"@en ;
    dcterms:identifier "transparency_trace" ;
    rdfs:comment "A documentation trace for process, problem-space, solution-space, build, evaluation, and contribution transparency."@en ;
    rdfs:subClassOf dsr:DocumentationArtifact ;
    skos:altLabel "audit trail"@en,
        "documentation trace"@en,
        "research trace"@en ;
    skos:closeMatch dsrv:transparency-trace ;
    skos:definition "A documentation trace for process, problem-space, solution-space, build, evaluation, and contribution transparency."@en ;
    skos:prefLabel "Transparency Trace"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:sourceAnchor "operational_synthesis:8.transparency_and_documentation_protocol",
        "theory_synthesis:12.1.dsr_transparency_framework" ;
    dsr:status "required" .

dsr:DSREntity a owl:Class ;
    rdfs:label "DSR Entity"@en ;
    dcterms:identifier "dsr_entity" ;
    rdfs:comment "Any entity, activity, claim, knowledge item, artifact, assessment, or trace represented in the DSR framework."@en ;
    skos:closeMatch dsrv:dsr-entity ;
    skos:definition "Any entity, activity, claim, knowledge item, artifact, assessment, or trace represented in the DSR framework."@en ;
    skos:prefLabel "DSR Entity"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "required" .

dsr:DesignEntity a owl:Class ;
    rdfs:label "Design Entity"@en ;
    dcterms:identifier "design_entity" ;
    rdfs:comment "An abstract or reusable artifact universal, artifact kind, design specification, or solution class that is the scientific object of DSR and the bearer of reusable design knowledge."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dsr:hasCapacitySpecification ;
            owl:someValuesFrom dsr:CapacitySpecification ],
        [ a owl:Restriction ;
            owl:onProperty dsr:hasUsePlan ;
            owl:someValuesFrom dsr:UsePlan ],
        [ a owl:Restriction ;
            owl:onProperty dsr:hasMakePlan ;
            owl:someValuesFrom dsr:MakePlan ],
        dsr:DSREntity ;
    owl:disjointWith dsr:ArtifactInstantiation ;
    skos:altLabel "abstract artifact"@en,
        "artifact kind"@en,
        "artifact universal"@en,
        "designed solution class"@en ;
    skos:closeMatch dsrv:design-entity ;
    skos:definition "An abstract or reusable artifact universal, artifact kind, design specification, or solution class that is the scientific object of DSR and the bearer of reusable design knowledge."@en ;
    skos:prefLabel "Design Entity"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:sourceAnchor "operational_synthesis:4.artifact_operationalization",
        "theory_synthesis:4.1.artifact_ontology" ;
    dsr:status "required" .

dsr:DSRStudy a owl:Class ;
    rdfs:label "DSR Study"@en ;
    dcterms:identifier "dsr_study" ;
    rdfs:comment "A complete design science research project or study that transforms a relevant problem instance and problem class into an evaluated design entity or artifact instantiation and codified design knowledge."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dsr:usesInputKnowledge ;
            owl:someValuesFrom dsr:InputKnowledge ],
        [ a owl:Restriction ;
            owl:onProperty dsr:hasProblemSpace ;
            owl:someValuesFrom dsr:ProblemSpace ],
        [ a owl:Restriction ;
            owl:onProperty dsr:addressesProblemInstance ;
            owl:someValuesFrom dsr:ProblemInstance ],
        [ a owl:Restriction ;
            owl:onProperty dsr:producesDesignEntity ;
            owl:someValuesFrom dsr:DesignEntity ],
        [ a owl:Restriction ;
            owl:onProperty dsr:occursInContext ;
            owl:someValuesFrom dsr:Context ],
        [ a owl:Restriction ;
            owl:onProperty dsr:hasEvaluation ;
            owl:someValuesFrom dsr:Evaluation ],
        [ a owl:Restriction ;
            owl:onProperty dsr:hasTransparencyTrace ;
            owl:someValuesFrom dsr:TransparencyTrace ],
        [ a owl:Restriction ;
            owl:onProperty dsr:hasReliabilityAssessment ;
            owl:someValuesFrom dsr:ReliabilityAssessment ],
        [ a owl:Restriction ;
            owl:onProperty dsr:hasRequirement ;
            owl:someValuesFrom dsr:Requirement ],
        [ a owl:Restriction ;
            owl:onProperty dsr:hasValidityAssessment ;
            owl:someValuesFrom dsr:ValidityAssessment ],
        [ a owl:Restriction ;
            owl:onProperty dsr:claimsContribution ;
            owl:someValuesFrom dsr:ContributionClaim ],
        dsr:DSREntity ;
    skos:altLabel "DSR project"@en,
        "artifact-centered inquiry"@en,
        "design science research study"@en ;
    skos:closeMatch dsrv:dsr-study ;
    skos:definition "A complete design science research project or study that transforms a relevant problem instance and problem class into an evaluated design entity or artifact instantiation and codified design knowledge."@en ;
    skos:prefLabel "DSR Study"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:sourceAnchor "operational_synthesis:1.core_definition",
        "theory_synthesis:1.definitional_nucleus" ;
    dsr:status "required" .
