# SPDX-License-Identifier: CC0-1.0
# dsr-ontology.ttl
# Core OWL ontology for the operational Design Science Research framework.
# Generated 2026-05-05.

@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dsr: <https://w3id.org/dsr-framework/ontology#> .
@prefix dsrv: <https://w3id.org/dsr-framework/vocab/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/dsr-framework/ontology> a owl:Ontology ;
    dcterms:created "2026-05-05"^^xsd:date ;
    dcterms:creator "DSR Framework project" ;
    dcterms:description "Core OWL ontology for the operational Design Science Research (DSR) framework. It represents DSR studies as linked problem, context, input-knowledge, requirement, artifact, demonstration, evaluation, evidence, design-knowledge, contribution, transparency, validity, reliability, replication, and anti-pattern entities. It is intended to be paired with the DSR SKOS controlled vocabulary and SHACL validation shapes."@en ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> ;
    dcterms:modified "2026-05-05"^^xsd:date ;
    dcterms:source "DSR Operational Synthesis.txt",
        "Theory of Design Science Research.txt",
        "Unified DSR source operational extraction corpus",
        "concept-inventory_v2.yaml" ;
    dcterms:title "DSR Core Ontology"@en ;
    vann:preferredNamespacePrefix "dsr" ;
    vann:preferredNamespaceUri "https://w3id.org/dsr-framework/ontology#" ;
    rdfs:comment "OWL restrictions in this file express the intended core semantic profile. Completeness, severity, and authoring conformance should be enforced in SHACL, JSON Schema, and repository validation profiles."@en ;
    rdfs:seeAlso dsrv: ;
    owl:versionIRI <https://w3id.org/dsr-framework/ontology/0.1.0> ;
    owl:versionInfo "0.1.0-draft" .

dsr:Architecture a owl:Class ;
    rdfs:label "Architecture"@en ;
    dcterms:identifier "architecture" ;
    rdfs:comment "A structural design entity describing components, interfaces, layers, or configuration principles for a technical or sociotechnical system."@en ;
    rdfs:subClassOf dsr:DesignEntity ;
    skos:closeMatch dsrv:architecture ;
    skos:definition "A structural design entity describing components, interfaces, layers, or configuration principles for a technical or sociotechnical system."@en ;
    skos:prefLabel "Architecture"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "conditional" .

dsr:ArtifactBlackBox a owl:NamedIndividual,
        dsr:AntiPattern ;
    rdfs:label "Artifact black box"@en ;
    dcterms:identifier "artifact_black_box" ;
    rdfs:comment "Reporting an artifact without sufficient specification, make plan, design rationale, or build transparency."@en ;
    skos:closeMatch dsrv:artifact-black-box ;
    skos:definition "Reporting an artifact without sufficient specification, make plan, design rationale, or build transparency."@en ;
    skos:prefLabel "Artifact black box"@en ;
    dsr:status "recommended" .

dsr:ArtifactSpace a owl:Class ;
    rdfs:label "Artifact Space"@en ;
    dcterms:identifier "artifact_space" ;
    rdfs:comment "The space of design entities, artifact universals, artifact instantiations, artifact specifications, make/use/capacity claims, and artifact networks."@en ;
    rdfs:subClassOf dsr:DSRSpace ;
    skos:closeMatch dsrv:artifact-space ;
    skos:definition "The space of design entities, artifact universals, artifact instantiations, artifact specifications, make/use/capacity claims, and artifact networks."@en ;
    skos:prefLabel "Artifact Space"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "recommended" .

dsr:ArtifactUniversal a owl:Class ;
    rdfs:label "Artifact Universal"@en ;
    dcterms:identifier "artifact_universal" ;
    rdfs:comment "A reusable artifact kind or design specification, distinct from a concrete implementation, that can be instantiated and evaluated through instances."@en ;
    rdfs:subClassOf dsr:DesignEntity ;
    skos:altLabel "abstract artifact"@en,
        "artifact class"@en,
        "artifact kind"@en ;
    skos:closeMatch dsrv:artifact-universal ;
    skos:definition "A reusable artifact kind or design specification, distinct from a concrete implementation, that can be instantiated and evaluated through instances."@en ;
    skos:prefLabel "Artifact Universal"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "recommended" .

dsr:BuildTrace a owl:Class ;
    rdfs:label "Build Trace"@en ;
    dcterms:identifier "build_trace" ;
    rdfs:comment "Documentation of construction activities, versions, code or materials, implementation choices, and capacity conformance evidence."@en ;
    rdfs:subClassOf dsr:TransparencyTrace ;
    skos:closeMatch dsrv:build-trace ;
    skos:definition "Documentation of construction activities, versions, code or materials, implementation choices, and capacity conformance evidence."@en ;
    skos:prefLabel "Build Trace"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "required" .

dsr:BuildTransparencyTrace a owl:Class ;
    rdfs:label "Build Transparency Trace"@en ;
    dcterms:identifier "build_transparency_trace" ;
    rdfs:comment "Documentation of design rationale, creative reasoning, collaboration, artifact construction choices, and implementation decisions."@en ;
    rdfs:subClassOf dsr:TransparencyTrace ;
    skos:closeMatch dsrv:build-transparency-trace ;
    skos:definition "Documentation of design rationale, creative reasoning, collaboration, artifact construction choices, and implementation decisions."@en ;
    skos:prefLabel "Build Transparency Trace"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "recommended" .

dsr:CommunicationSpace a owl:Class ;
    rdfs:label "Communication and Transparency Space"@en ;
    dcterms:identifier "communication_space" ;
    rdfs:comment "The reporting, repository, audience, DSR Grid, and transparency layer that makes the study reviewable, reusable, auditable, and practically intelligible."@en ;
    rdfs:subClassOf dsr:DSRSpace ;
    skos:closeMatch dsrv:communication-space ;
    skos:definition "The reporting, repository, audience, DSR Grid, and transparency layer that makes the study reviewable, reusable, auditable, and practically intelligible."@en ;
    skos:prefLabel "Communication and Transparency Space"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "recommended" .

dsr:Construct a owl:Class ;
    rdfs:label "Construct"@en ;
    dcterms:identifier "construct" ;
    rdfs:comment "A conceptual vocabulary, term set, or symbolic representation used to describe a problem or solution domain."@en ;
    rdfs:subClassOf dsr:DesignEntity ;
    skos:closeMatch dsrv:construct ;
    skos:definition "A conceptual vocabulary, term set, or symbolic representation used to describe a problem or solution domain."@en ;
    skos:prefLabel "Construct"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "conditional" .

dsr:ContextSpace a owl:Class ;
    rdfs:label "Context Space"@en ;
    dcterms:identifier "context_space" ;
    rdfs:comment "The organizational, technical, social, temporal, cultural, regulatory, resource, stakeholder, and artifact-network conditions that bound DSR claims."@en ;
    rdfs:subClassOf dsr:DSRSpace ;
    skos:closeMatch dsrv:context-space ;
    skos:definition "The organizational, technical, social, temporal, cultural, regulatory, resource, stakeholder, and artifact-network conditions that bound DSR claims."@en ;
    skos:prefLabel "Context Space"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "recommended" .

dsr:ContributionTransparencyTrace a owl:Class ;
    rdfs:label "Contribution Transparency Trace"@en ;
    dcterms:identifier "contribution_transparency_trace" ;
    rdfs:comment "Documentation of scientific and practical contribution, design knowledge, audience-specific communication, evidence basis, and limits."@en ;
    rdfs:subClassOf dsr:TransparencyTrace ;
    skos:closeMatch dsrv:contribution-transparency-trace ;
    skos:definition "Documentation of scientific and practical contribution, design knowledge, audience-specific communication, evidence basis, and limits."@en ;
    skos:prefLabel "Contribution Transparency Trace"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "recommended" .

dsr:DSRGridSummary a owl:Class ;
    rdfs:label "DSR Grid Summary"@en ;
    dcterms:identifier "dsr_grid_summary" ;
    rdfs:comment "A six-dimension summary covering problem, input knowledge, research process, key concepts, solution, and output knowledge."@en ;
    rdfs:subClassOf dsr:DocumentationArtifact ;
    skos:closeMatch dsrv:dsr-grid-summary ;
    skos:definition "A six-dimension summary covering problem, input knowledge, research process, key concepts, solution, and output knowledge."@en ;
    skos:prefLabel "DSR Grid Summary"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "recommended" .

dsr:DesignPattern a owl:Class ;
    rdfs:label "Design Pattern"@en ;
    dcterms:identifier "design_pattern" ;
    rdfs:comment "A reusable problem-solution schema including problem, context, forces, solution, rationale, consequences, and implementation guidance."@en ;
    rdfs:subClassOf dsr:DesignEntity,
        dsr:DesignKnowledge ;
    skos:closeMatch dsrv:design-pattern ;
    skos:definition "A reusable problem-solution schema including problem, context, forces, solution, rationale, consequences, and implementation guidance."@en ;
    skos:prefLabel "Design Pattern"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "conditional" .

dsr:DesignPrinciple a owl:Class ;
    rdfs:label "Design Principle"@en ;
    dcterms:identifier "design_principle" ;
    rdfs:comment "A transferable prescriptive design-knowledge statement linking context, intervention or action, mechanism or rationale, outcome, and boundary conditions."@en ;
    rdfs:subClassOf dsr:DesignEntity,
        dsr:DesignKnowledge ;
    skos:closeMatch dsrv:design-principle ;
    skos:definition "A transferable prescriptive design-knowledge statement linking context, intervention or action, mechanism or rationale, outcome, and boundary conditions."@en ;
    skos:prefLabel "Design Principle"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "conditional" .

dsr:DesignSpace a owl:Class ;
    rdfs:label "Design Space"@en ;
    dcterms:identifier "design_space" ;
    rdfs:comment "The search and construction space containing objectives, requirements, design rationale, make plans, use plans, capacities, alternatives, and decisions."@en ;
    rdfs:subClassOf dsr:DSRSpace ;
    skos:closeMatch dsrv:design-space ;
    skos:definition "The search and construction space containing objectives, requirements, design rationale, make plans, use plans, capacities, alternatives, and decisions."@en ;
    skos:prefLabel "Design Space"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "recommended" .

dsr:DesignTheory a owl:Class ;
    rdfs:label "Design Theory"@en ;
    dcterms:identifier "design_theory" ;
    rdfs:comment "A structured prescriptive theory including purpose and scope, constructs, form and function, mutability, propositions, justificatory knowledge, implementation principles, and expository instantiation."@en ;
    rdfs:subClassOf dsr:DesignEntity,
        dsr:DesignKnowledge ;
    skos:closeMatch dsrv:design-theory ;
    skos:definition "A structured prescriptive theory including purpose and scope, constructs, form and function, mutability, propositions, justificatory knowledge, implementation principles, and expository instantiation."@en ;
    skos:prefLabel "Design Theory"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "conditional" .

dsr:EvaluationFinding a owl:Class ;
    rdfs:label "Evaluation Finding"@en ;
    dcterms:identifier "evaluation_finding" ;
    rdfs:comment "A result, interpretation, or limitation produced by evaluation and used to support or constrain claims."@en ;
    rdfs:subClassOf dsr:EvaluationEvidence ;
    skos:closeMatch dsrv:evaluation-finding ;
    skos:definition "A result, interpretation, or limitation produced by evaluation and used to support or constrain claims."@en ;
    skos:prefLabel "Evaluation Finding"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "required" .

dsr:EvaluationMismatch a owl:NamedIndividual,
        dsr:AntiPattern ;
    rdfs:label "Evaluation mismatch"@en ;
    dcterms:identifier "evaluation_mismatch" ;
    rdfs:comment "Misalignment between evaluation object, criteria, evidence mode, context, maturity, and claim type."@en ;
    skos:closeMatch dsrv:evaluation-mismatch ;
    skos:definition "Misalignment between evaluation object, criteria, evidence mode, context, maturity, and claim type."@en ;
    skos:prefLabel "Evaluation mismatch"@en ;
    dsr:status "recommended" .

dsr:EvaluationSpace a owl:Class ;
    rdfs:label "Evaluation Space"@en ;
    dcterms:identifier "evaluation_space" ;
    rdfs:comment "The structured relation among artifact, claim type, timing, setting, evidence mode, criteria, stakeholders, findings, and limitations."@en ;
    rdfs:subClassOf dsr:DSRSpace ;
    skos:closeMatch dsrv:evaluation-space ;
    skos:definition "The structured relation among artifact, claim type, timing, setting, evidence mode, criteria, stakeholders, findings, and limitations."@en ;
    skos:prefLabel "Evaluation Space"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "recommended" .

dsr:EvaluationTransparencyTrace a owl:Class ;
    rdfs:label "Evaluation Transparency Trace"@en ;
    dcterms:identifier "evaluation_transparency_trace" ;
    rdfs:comment "Documentation of evaluation methods, criteria, evidence, measures, formative and summative findings, and fitness for use or evolution."@en ;
    rdfs:subClassOf dsr:TransparencyTrace ;
    skos:closeMatch dsrv:evaluation-transparency-trace ;
    skos:definition "Documentation of evaluation methods, criteria, evidence, measures, formative and summative findings, and fitness for use or evolution."@en ;
    skos:prefLabel "Evaluation Transparency Trace"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "recommended" .

dsr:ExPostDSRification a owl:NamedIndividual,
        dsr:AntiPattern ;
    rdfs:label "Ex-post DSR-ification"@en ;
    dcterms:identifier "ex_post_dsr_ification" ;
    rdfs:comment "Retrofitting DSR language to a completed local project without traceable problem, design, evaluation, or contribution grounding."@en ;
    skos:closeMatch dsrv:ex-post-dsr-ification ;
    skos:definition "Retrofitting DSR language to a completed local project without traceable problem, design, evaluation, or contribution grounding."@en ;
    skos:prefLabel "Ex-post DSR-ification"@en ;
    dsr:status "recommended" .

dsr:Framework a owl:Class ;
    rdfs:label "Framework"@en ;
    dcterms:identifier "framework" ;
    rdfs:comment "An organizing structure for concepts, dimensions, criteria, relationships, or activities in DSR or a domain of practice."@en ;
    rdfs:subClassOf dsr:DesignEntity ;
    skos:closeMatch dsrv:framework ;
    skos:definition "An organizing structure for concepts, dimensions, criteria, relationships, or activities in DSR or a domain of practice."@en ;
    skos:prefLabel "Framework"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "conditional" .

dsr:InstantiationClass a owl:Class ;
    rdfs:label "Instantiation Class"@en ;
    dcterms:identifier "instantiation_class" ;
    rdfs:comment "A reusable class of implemented artifacts, prototypes, systems, interventions, or process implementations represented at the artifact-kind level."@en ;
    rdfs:subClassOf dsr:DesignEntity ;
    skos:closeMatch dsrv:instantiation-class ;
    skos:definition "A reusable class of implemented artifacts, prototypes, systems, interventions, or process implementations represented at the artifact-kind level."@en ;
    skos:prefLabel "Instantiation Class"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "conditional" .

dsr:KnowledgeContribution a owl:Class ;
    rdfs:label "Knowledge Contribution"@en ;
    dcterms:identifier "knowledge_contribution" ;
    rdfs:comment "A codified addition to DSR or domain knowledge characterized by contribution object, knowledge goal, knowledge scope, novelty, maturity, audience, evidence basis, and boundary conditions."@en ;
    rdfs:subClassOf dsr:OutputKnowledge ;
    skos:closeMatch dsrv:knowledge-contribution ;
    skos:definition "A codified addition to DSR or domain knowledge characterized by contribution object, knowledge goal, knowledge scope, novelty, maturity, audience, evidence basis, and boundary conditions."@en ;
    skos:prefLabel "Knowledge Contribution"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "required" .

dsr:KnowledgeGoal a owl:Class ;
    rdfs:label "Knowledge Goal"@en ;
    dcterms:identifier "knowledge_goal" ;
    rdfs:comment "The purpose of knowledge produced, such as definitional, descriptive, explanatory, predictive, evaluative, methodological, normative, or prescriptive."@en ;
    rdfs:subClassOf dsr:KnowledgeType ;
    skos:closeMatch dsrv:knowledge-goal ;
    skos:definition "The purpose of knowledge produced, such as definitional, descriptive, explanatory, predictive, evaluative, methodological, normative, or prescriptive."@en ;
    skos:prefLabel "Knowledge Goal"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "recommended" .

dsr:KnowledgeScope a owl:Class ;
    rdfs:label "Knowledge Scope"@en ;
    dcterms:identifier "knowledge_scope" ;
    rdfs:comment "The level of generality or projectability of knowledge, ranging from idiographic or local to nomothetic or general."@en ;
    rdfs:subClassOf dsr:KnowledgeType ;
    skos:closeMatch dsrv:knowledge-scope ;
    skos:definition "The level of generality or projectability of knowledge, ranging from idiographic or local to nomothetic or general."@en ;
    skos:prefLabel "Knowledge Scope"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "recommended" .

dsr:KnowledgeSpace a owl:Class ;
    rdfs:label "Knowledge Space"@en ;
    dcterms:identifier "knowledge_space" ;
    rdfs:comment "The generated design knowledge, output knowledge, contribution claim, boundary conditions, and accumulated knowledge-base updates."@en ;
    rdfs:subClassOf dsr:DSRSpace ;
    skos:closeMatch dsrv:knowledge-space ;
    skos:definition "The generated design knowledge, output knowledge, contribution claim, boundary conditions, and accumulated knowledge-base updates."@en ;
    skos:prefLabel "Knowledge Space"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "recommended" .

dsr:MakeClaim a owl:Class ;
    rdfs:label "Make Claim"@en ;
    dcterms:identifier "make_claim" ;
    rdfs:comment "A claim that executing a make plan yields an artifact instance with specified capacities satisfying a make goal."@en ;
    rdfs:subClassOf dsr:Claim ;
    skos:closeMatch dsrv:make-claim ;
    skos:definition "A claim that executing a make plan yields an artifact instance with specified capacities satisfying a make goal."@en ;
    skos:prefLabel "Make Claim"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "conditional" .

dsr:Measure a owl:Class ;
    rdfs:label "Measure"@en ;
    dcterms:identifier "measure" ;
    rdfs:comment "An instrument, metric, indicator, test, observation, scale, analytic output, or data collection item used in evaluation."@en ;
    rdfs:subClassOf dsr:DSREntity ;
    skos:closeMatch dsrv:measure ;
    skos:definition "An instrument, metric, indicator, test, observation, scale, analytic output, or data collection item used in evaluation."@en ;
    skos:prefLabel "Measure"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "recommended" .

dsr:Method a owl:Class ;
    rdfs:label "Method"@en ;
    dcterms:identifier "method" ;
    rdfs:comment "A procedure, algorithm, process, technique, or methodology for accomplishing a design, implementation, evaluation, or research task."@en ;
    rdfs:subClassOf dsr:DesignEntity ;
    skos:closeMatch dsrv:method ;
    skos:definition "A procedure, algorithm, process, technique, or methodology for accomplishing a design, implementation, evaluation, or research task."@en ;
    skos:prefLabel "Method"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "conditional" .

dsr:Model a owl:Class ;
    rdfs:label "Model"@en ;
    dcterms:identifier "model" ;
    rdfs:comment "An abstraction of relationships, structures, processes, states, mechanisms, or design logic."@en ;
    rdfs:subClassOf dsr:DesignEntity ;
    skos:closeMatch dsrv:model ;
    skos:definition "An abstraction of relationships, structures, processes, states, mechanisms, or design logic."@en ;
    skos:prefLabel "Model"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "conditional" .

dsr:NonCodifiedKnowledge a owl:NamedIndividual,
        dsr:AntiPattern ;
    rdfs:label "Non-codified knowledge"@en ;
    dcterms:identifier "non_codified_knowledge" ;
    rdfs:comment "Failing to codify design knowledge, boundary conditions, contribution claims, or projectability beyond the local artifact."@en ;
    skos:closeMatch dsrv:non-codified-knowledge ;
    skos:definition "Failing to codify design knowledge, boundary conditions, contribution claims, or projectability beyond the local artifact."@en ;
    skos:prefLabel "Non-codified knowledge"@en ;
    dsr:status "recommended" .

dsr:OntologyArtifact a owl:Class ;
    rdfs:label "Ontology Artifact"@en ;
    dcterms:identifier "ontology_artifact" ;
    rdfs:comment "A formalized conceptualization of classes, properties, relationships, and constraints produced or used as a DSR artifact."@en ;
    rdfs:subClassOf dsr:DesignEntity ;
    skos:definition "A formalized conceptualization of classes, properties, relationships, and constraints produced or used as a DSR artifact."@en ;
    skos:prefLabel "Ontology Artifact"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "conditional" .

dsr:ProblemSpaceTransparencyTrace a owl:Class ;
    rdfs:label "Problem-Space Transparency Trace"@en ;
    dcterms:identifier "problem_space_transparency_trace" ;
    rdfs:comment "Documentation of context, stakeholders, scope, goals, timeframe, resources, constraints, and boundary conditions."@en ;
    rdfs:subClassOf dsr:TransparencyTrace ;
    skos:closeMatch dsrv:problem-space-transparency-trace ;
    skos:definition "Documentation of context, stakeholders, scope, goals, timeframe, resources, constraints, and boundary conditions."@en ;
    skos:prefLabel "Problem-Space Transparency Trace"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "recommended" .

dsr:ProcessArtifact a owl:Class ;
    rdfs:label "Process Artifact"@en ;
    dcterms:identifier "process_artifact" ;
    rdfs:comment "A designed process, workflow, lifecycle, checklist, grid, or method artifact used to guide DSR or practice."@en ;
    rdfs:subClassOf dsr:DesignEntity ;
    skos:closeMatch dsrv:process-artifact ;
    skos:definition "A designed process, workflow, lifecycle, checklist, grid, or method artifact used to guide DSR or practice."@en ;
    skos:prefLabel "Process Artifact"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "conditional" .

dsr:ProcessTransparencyTrace a owl:Class ;
    rdfs:label "Process Transparency Trace"@en ;
    dcterms:identifier "process_transparency_trace" ;
    rdfs:comment "Documentation of actual activities, reasoning, sequence, iterations, emergent decisions, and design log."@en ;
    rdfs:subClassOf dsr:TransparencyTrace ;
    skos:closeMatch dsrv:process-transparency-trace ;
    skos:definition "Documentation of actual activities, reasoning, sequence, iterations, emergent decisions, and design log."@en ;
    skos:prefLabel "Process Transparency Trace"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "recommended" .

dsr:RepositoryPackage a owl:Class ;
    rdfs:label "Repository Package"@en ;
    dcterms:identifier "repository_package" ;
    rdfs:comment "A reusable package containing data, code, screenshots, simulations, logs, instruments, models, documentation, source registry, concept inventory, schemas, shapes, examples, and validation scripts."@en ;
    rdfs:subClassOf dsr:DocumentationArtifact ;
    skos:closeMatch dsrv:repository-package ;
    skos:definition "A reusable package containing data, code, screenshots, simulations, logs, instruments, models, documentation, source registry, concept inventory, schemas, shapes, examples, and validation scripts."@en ;
    skos:prefLabel "Repository Package"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "recommended" .

dsr:ResearchQuestion a owl:Class ;
    rdfs:label "Research Question"@en ;
    dcterms:identifier "research_question" ;
    rdfs:comment "A problem-, objective-, artifact-, design-, evaluation-, or knowledge-oriented inquiry formulation for a DSR study."@en ;
    rdfs:subClassOf dsr:DSREntity ;
    skos:closeMatch dsrv:research-question ;
    skos:definition "A problem-, objective-, artifact-, design-, evaluation-, or knowledge-oriented inquiry formulation for a DSR study."@en ;
    skos:prefLabel "Research Question"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "recommended" .

dsr:RoutineDesignOverclaim a owl:NamedIndividual,
        dsr:AntiPattern ;
    rdfs:label "Routine design overclaim"@en ;
    dcterms:identifier "routine_design_overclaim" ;
    rdfs:comment "Claiming a routine implementation as DSR without novelty, design knowledge, projectability, or adequate evaluation."@en ;
    skos:closeMatch dsrv:routine-design-overclaim ;
    skos:definition "Claiming a routine implementation as DSR without novelty, design knowledge, projectability, or adequate evaluation."@en ;
    skos:prefLabel "Routine design overclaim"@en ;
    dsr:status "recommended" .

dsr:SocioTechnicalIntervention a owl:Class ;
    rdfs:label "Socio-Technical Intervention"@en ;
    dcterms:identifier "socio_technical_intervention" ;
    rdfs:comment "A coordinated human, organizational, technical, and process configuration intended to change practice and generate situated utility."@en ;
    rdfs:subClassOf dsr:DesignEntity ;
    skos:closeMatch dsrv:socio-technical-intervention ;
    skos:definition "A coordinated human, organizational, technical, and process configuration intended to change practice and generate situated utility."@en ;
    skos:prefLabel "Socio-Technical Intervention"@en ;
    dsr:ambiguityLevel "low" ;
    dsr:status "conditional" .

dsr:SolutionSpace a owl:Class ;
    rdfs:label "Solution Space"@en ;
    dcterms:identifier "solution_space" ;
    rdfs:comment "The prior artifacts, theories, technologies, methods, design alternatives, and patterns used to ground the artifact."@en ;
    rdfs:subClassOf dsr:DSRSpace ;
    skos:closeMatch dsrv:solution-space ;
