    dsrmeta:ambiguityLevel "low" ;
    dsrmeta:disambiguationNote "Use only as a diagnostic warning or failure pattern; do not use as a neutral descriptor of a valid DSR contribution."@en ;
    dsrmeta:sourceCitationAnchor "operational_synthesis:10.anti_pattern_controls",
        "theory_synthesis:12.1.dsr_transparency_framework",
        "theory_synthesis:16.boundary_conditions_and_anti_patterns" ;
    dsrmeta:status "conditional" ;
    dsrmeta:termCategory "anti_pattern_terms" ;
    dsrmeta:termKind "anti_pattern" ;
    dsrmeta:usageNote "Use to flag a DSR anti-pattern. Severity: sh:Violation. Status: conditional. Warning condition: Artifact/design entity present but missing make_plan, use_plan, capacity_specification, design_rationale, or build_trace. Recommended correction: Require build transparency, design log, artifact specification, and make/use/capacity documentation."@en .

