dsrv:ap-artifact-black-box a skos:Concept ;
    dcterms:identifier "ap_artifact_black_box" ;
    dcterms:source "concept-inventory_v2.yaml" ;
    skos:broader dsrv:dsr-anti-pattern ;
    skos:definition "Artifact is reported without make/use plan, capacity specification, build rationale, or construction trace."@en ;
