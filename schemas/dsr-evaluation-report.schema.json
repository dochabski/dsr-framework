{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dochabski.github.io/dsr-framework/schemas/dsr-evaluation-report.schema.json",
  "title": "DSR Evaluation Report Schema",
  "description": "Validates evaluation-report templates and future evaluation-report instances, retaining source basis, report body, validation rules, acceptance criteria, and quality-gate alignment.",
  "type": "object",
  "anyOf": [
    {
      "required": [
        "evaluation_report_template"
      ]
    },
    {
      "required": [
        "evaluation_report",
        "item_id",
        "item_type",
        "title",
        "purpose",
        "status",
        "version",
        "owner",
        "source_basis",
        "related_items"
      ]
    }
  ],
  "additionalProperties": false,
  "properties": {
    "evaluation_report_template": {
      "type": "object",
      "required": [
        "item_id",
        "item_type",
        "title",
        "purpose",
        "status",
        "version",
        "owner",
        "source_basis",
        "related_items",
        "report"
      ],
      "properties": {
        "item_id": {
          "type": "string",
          "minLength": 1
        },
        "item_type": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "object"
        },
        "target_path": {
          "type": "string"
        },
        "target_conformance": {
          "type": "string"
        },
        "template_scope": {
          "type": "object"
        },
        "source_basis": {
          "type": "array"
        },
        "related_items": {
          "type": "object"
        },
        "instructions_for_use": {
          "type": "array"
        },
        "report": {
          "type": "object"
        },
        "validation_rules": {
          "type": [
            "array",
            "object"
          ]
        },
        "acceptance_criteria": {
          "type": "array"
        },
        "quality_gate_alignment": {
          "type": "object"
        },
        "open_questions": {
          "type": "array"
        },
        "change_history": {
          "type": "array"
        },
        "evaluation_report": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "evaluation_report": {
      "type": "object",
      "additionalProperties": true
    },
    "item_id": {},
    "item_type": {},
    "title": {},
    "purpose": {},
    "status": {},
    "version": {},
    "owner": {},
    "source_basis": {},
    "related_items": {},
    "change_history": {}
  }
}
