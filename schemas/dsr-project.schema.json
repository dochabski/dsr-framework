{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dochabski.github.io/dsr-framework/schemas/dsr-project.schema.json",
  "$comment": "SPDX-License-Identifier: CC0-1.0",
  "title": "DSR Project Record Schema",
  "description": "Validates a full Design Science Research project record for the DSR Framework, including project identity, problem space, solution space, artifact, design process, demonstration, evaluation, contribution, transparency, quality, conformance, and traceability.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project",
    "problem_space",
    "solution_space",
    "artifact",
    "design_process",
    "lifecycle",
    "demonstration",
    "evaluation",
    "contribution",
    "transparency",
    "quality",
    "conformance",
    "traceability"
  ],
  "properties": {
    "project": {
      "$ref": "#/$defs/project_metadata"
    },
    "problem_space": {
      "$ref": "#/$defs/problem_space"
    },
    "solution_space": {
      "$ref": "#/$defs/solution_space"
    },
    "artifact": {
      "$ref": "#/$defs/artifact_record"
    },
    "design_process": {
      "$ref": "#/$defs/design_process"
    },
    "lifecycle": {
      "$ref": "#/$defs/lifecycle_record"
    },
    "demonstration": {
      "$ref": "#/$defs/demonstration_record"
    },
    "evaluation": {
      "$ref": "#/$defs/evaluation_record"
    },
    "contribution": {
      "$ref": "#/$defs/contribution_record"
    },
    "transparency": {
      "$ref": "#/$defs/transparency_record"
    },
    "quality": {
      "$ref": "#/$defs/quality_record"
    },
    "responsible_design": {
      "$ref": "#/$defs/responsible_design_record"
    },
    "evidence_repository": {
      "type": "array",
      "description": "Reusable evidence objects referenced by problem, artifact, evaluation, contribution, transparency, or quality sections.",
      "items": {
        "$ref": "#/$defs/evidence_item"
      }
    },
    "review": {
      "$ref": "#/$defs/review_record"
    },
    "open_questions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/open_question"
      }
    },
    "extensions": {
      "type": "object",
      "description": "Explicit extension space for project-specific fields not yet standardized by the DSR Framework.",
      "additionalProperties": true
    }
  },
  "$defs": {
    "stable_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Lower-snake-case stable identifier."
    },
    "repository_path": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._/-]+$",
      "description": "Repository-relative path using forward slashes."
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "date_string": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "in_review",
        "approved",
        "released",
        "superseded",
        "deprecated",
        "archived"
      ]
    },
    "evidence_status": {
      "type": "string",
      "enum": [
        "mapped",
        "partially_mapped",
        "not_yet_mapped",
        "not_applicable"
      ]
    },
    "conformance_level": {
      "type": "string",
      "enum": [
        "l0_draft",
        "l1_documented",
        "l2_reviewable",
        "l3_exercisable",
        "l4_reusable",
        "l5_archival_publication_ready"
      ]
    },
    "project_class": {
      "type": "string",
      "enum": [
        "design_science_research_project",
        "artifact_package_project",
        "framework_development_project",
        "evaluation_project",
        "documentation_protocol_project",
        "other"
      ]
    },
    "problem_type": {
      "type": "string",
      "enum": [
        "wicked_problem",
        "socio_technical_problem",
        "technical_problem",
        "organizational_problem",
        "methodological_problem",
        "conceptual_problem",
        "educational_problem",
        "policy_or_governance_problem",
        "other"
      ]
    },
    "stakeholder_role": {
      "type": "string",
      "enum": [
        "researcher",
        "designer",
        "developer",
        "maker",
        "user",
        "practitioner",
        "reviewer",
        "manager",
        "sponsor",
        "policy_or_public",
        "maintainer",
        "other"
      ]
    },
    "objective_type": {
      "type": "string",
      "enum": [
        "functional_requirement",
        "nonfunctional_requirement",
        "documentation_requirement",
        "evaluation_requirement",
        "ethical_or_normative_requirement",
        "constraint",
        "success_criterion",
        "other"
      ]
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "construct",
        "model",
        "method",
        "instantiation",
        "framework",
        "taxonomy",
        "ontology",
        "guideline",
        "pattern",
        "protocol",
        "software",
        "workflow",
        "dataset",
        "metric",
        "checklist",
        "template",
        "repository_package",
        "mixed",
        "other"
      ]
    },
    "artifact_materiality": {
      "type": "string",
      "enum": [
        "conceptual_only",
        "symbolic",
        "software",
        "data",
        "physical",
        "socio_technical",
        "mixed",
        "other"
      ]
    },
    "abstraction_level": {
      "type": "string",
      "enum": [
        "highly_abstract",
        "moderately_abstract",
        "implementation_oriented",
        "instance_specific",
        "mixed"
      ]
    },
    "lifecycle_stage": {
      "type": "string",
      "enum": [
        "problem_identification",
        "objective_definition",
        "solution_space_grounding",
        "requirements_definition",
        "design_and_development",
        "build",
        "demonstration",
        "evaluation",
        "contribution_positioning",
        "communication",
        "release",
        "maintenance",
        "retirement"
      ]
    },
    "stage_status": {
      "type": "string",
      "enum": [
        "not_started",
        "planned",
        "in_progress",
        "complete",
        "deferred",
        "not_applicable"
      ]
    },
    "evaluation_status": {
      "type": "string",
      "enum": [
        "not_planned",
        "planned",
        "in_progress",
        "complete",
        "not_applicable"
      ]
    },
    "evaluation_method_family": {
      "type": "string",
      "enum": [
        "analytical",
        "experimental",
        "observational",
        "testing",
        "simulation",
        "expert_review",
        "case_study",
        "field_study",
        "action_research",
        "literature_based_argument",
        "demonstration",
        "not_evaluated",
        "other"
      ]
    },
    "evaluation_timing": {
      "type": "string",
      "enum": [
        "formative",
        "summative",
        "ex_ante",
        "ex_post",
        "continuous",
        "not_applicable"
      ]
    },
    "knowledge_goal": {
      "type": "string",
      "enum": [
        "definitional",
        "descriptive",
        "explanatory",
        "predictive",
        "explanatory_predictive",
        "prescriptive",
        "methodological",
        "evaluative",
        "normative",
        "other"
      ]
    },
    "knowledge_scope": {
      "type": "string",
      "enum": [
        "idiographic_context_specific",
        "nomothetic_general",
        "projectable_to_problem_class",
        "mixed",
        "other"
      ]
    },
    "contribution_type": {
      "type": "string",
      "enum": [
        "new_artifact",
        "artifact_improvement",
        "method_extension",
        "theory_extension",
        "design_principle",
        "evaluation_evidence",
        "taxonomy_or_ontology",
        "repository_or_package",
        "replication_or_projectability_evidence",
        "other"
      ]
    },
    "transparency_dimension": {
      "type": "string",
      "enum": [
        "process_transparency",
        "problem_space_transparency",
        "solution_space_transparency",
        "build_transparency",
        "evaluation_transparency",
        "contribution_transparency"
      ]
    },
    "quality_dimension": {
      "type": "string",
      "enum": [
        "consistency",
        "coherence",
        "cogency",
        "correspondence",
        "dsr_transparency",
        "reviewability",
        "validity",
        "reliability",
        "replication",
        "projectability",
        "utility",
        "artifact_quality",
        "contribution_quality"
      ]
    },
    "quality_result": {
      "type": "string",
      "enum": [
        "pass",
        "partial",
        "fail",
        "not_applicable",
        "not_yet_reviewed"
      ]
    },
    "related_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_id",
        "relationship"
      ],
      "properties": {
        "item_id": {
          "$ref": "#/$defs/stable_id"
        },
        "path": {
          "$ref": "#/$defs/repository_path"
        },
        "relationship": {
          "$ref": "#/$defs/non_empty_string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "source_basis_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "evidence_status"
      ],
      "properties": {
        "source_id": {
          "$ref": "#/$defs/stable_id"
        },
        "source_type": {
          "type": "string",
          "enum": [
            "documentation_protocol",
            "dsr_corpus",
            "model",
            "vocabulary",
            "schema",
            "template",
            "user_instruction",
            "external_source",
            "other"
          ]
        },
        "citation": {
          "type": "string"
        },
        "evidence_status": {
          "$ref": "#/$defs/evidence_status"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "change_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "date",
        "change_summary"
      ],
      "properties": {
        "version": {
          "$ref": "#/$defs/non_empty_string"
        },
        "date": {
          "$ref": "#/$defs/date_string"
        },
        "change_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "changed_by": {
          "type": "string"
        }
      }
    },
    "evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "evidence_type",
        "description",
        "status"
      ],
      "properties": {
        "evidence_id": {
          "$ref": "#/$defs/stable_id"
        },
        "evidence_type": {
          "type": "string",
          "enum": [
            "bibliographic_source",
            "artifact_file",
            "design_record",
            "evaluation_data",
            "evaluation_report",
            "review_record",
            "demonstration_output",
            "repository_link",
            "citation_anchor",
            "other"
          ]
        },
        "description": {
          "$ref": "#/$defs/non_empty_string"
        },
        "location": {
          "type": "string"
        },
        "source_ref": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/evidence_status"
        },
        "limitations": {
          "type": "string"
        }
      }
    },
    "stakeholder": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stakeholder_id",
        "role",
        "description"
      ],
      "properties": {
        "stakeholder_id": {
          "$ref": "#/$defs/stable_id"
        },
        "role": {
          "$ref": "#/$defs/stakeholder_role"
        },
        "description": {
          "$ref": "#/$defs/non_empty_string"
        },
        "involvement_stages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lifecycle_stage"
          }
        },
        "needs_or_interests": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      }
    },
    "objective": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "objective_id",
        "objective",
        "objective_type"
      ],
      "properties": {
        "objective_id": {
          "$ref": "#/$defs/stable_id"
        },
        "objective": {
          "$ref": "#/$defs/non_empty_string"
        },
        "objective_type": {
          "$ref": "#/$defs/objective_type"
        },
        "rationale": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stable_id"
          }
        }
      }
    },
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement_id",
        "requirement_text",
        "requirement_type",
        "priority"
      ],
      "properties": {
        "requirement_id": {
          "$ref": "#/$defs/stable_id"
        },
        "requirement_text": {
          "$ref": "#/$defs/non_empty_string"
        },
        "requirement_type": {
          "$ref": "#/$defs/objective_type"
        },
        "priority": {
          "type": "string",
          "enum": [
            "must",
            "should",
            "may",
            "wont"
          ]
        },
        "verification_method": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stable_id"
          }
        }
      }
    },
    "success_criterion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "criterion_id",
        "criterion",
        "assessment_method"
      ],
      "properties": {
        "criterion_id": {
          "$ref": "#/$defs/stable_id"
        },
        "criterion": {
          "$ref": "#/$defs/non_empty_string"
        },
        "assessment_method": {
          "$ref": "#/$defs/non_empty_string"
        },
        "threshold": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stable_id"
          }
        }
      }
    },
    "artifact_component": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "component_id",
        "component_name",
        "component_type",
        "component_function"
      ],
      "properties": {
        "component_id": {
          "$ref": "#/$defs/stable_id"
        },
        "component_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "component_type": {
          "$ref": "#/$defs/artifact_type"
        },
        "component_function": {
          "$ref": "#/$defs/non_empty_string"
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "boundary_notes": {
          "type": "string"
        }
      }
    },
    "plan_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "step_name",
        "step_description"
      ],
      "properties": {
        "step_id": {
          "$ref": "#/$defs/stable_id"
        },
        "step_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "step_description": {
          "$ref": "#/$defs/non_empty_string"
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "responsible_role": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stable_id"
          }
        }
      }
    },
    "project_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_id",
        "title",
        "purpose",
        "status",
        "version",
        "owner",
        "project_class",
        "source_basis",
        "related_items",
        "change_history"
      ],
      "properties": {
        "project_id": {
          "$ref": "#/$defs/stable_id"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "purpose": {
          "$ref": "#/$defs/non_empty_string"
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "version": {
          "$ref": "#/$defs/non_empty_string"
        },
        "owner": {
          "$ref": "#/$defs/non_empty_string"
        },
        "project_class": {
          "$ref": "#/$defs/project_class"
        },
        "start_date": {
          "$ref": "#/$defs/date_string"
        },
        "end_date": {
          "$ref": "#/$defs/date_string"
        },
        "repository_path": {
          "$ref": "#/$defs/repository_path"
        },
        "source_basis": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/source_basis_item"
          }
        },
        "related_items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/related_item"
          }
        },
        "change_history": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/change_entry"
          }
        }
      }
    },
    "problem_space": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "problem_id",
        "problem_statement",
        "problem_type",
        "context",
        "stakeholders",
        "objectives",
        "requirements",
        "success_criteria",
        "boundary_conditions"
      ],
      "properties": {
        "problem_id": {
          "$ref": "#/$defs/stable_id"
        },
        "problem_statement": {
          "$ref": "#/$defs/non_empty_string"
        },
        "problem_type": {
          "$ref": "#/$defs/problem_type"
        },
        "context": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "domain",
            "setting"
          ],
          "properties": {
            "domain": {
              "$ref": "#/$defs/non_empty_string"
            },
            "setting": {
              "type": "string"
            },
            "geographic_or_regulatory_context": {
              "type": "string"
            },
            "technological_context": {
              "type": "string"
            },
            "social_or_cultural_context": {
              "type": "string"
            }
          }
        },
        "stakeholders": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stakeholder"
          }
        },
        "objectives": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/objective"
          }
        },
        "requirements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/requirement"
          }
        },
        "success_criteria": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/success_criterion"
          }
        },
        "boundary_conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "current_gap_or_unsatisfactory_state": {
          "type": "string"
        },
        "practical_relevance_claim": {
          "type": "string"
        },
        "source_basis": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_basis_item"
          }
        }
      }
    },
    "solution_space": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "solution_space_id",
        "knowledge_base",
        "existing_artifacts",
        "design_constraints",
        "assumptions"
      ],
      "properties": {
        "solution_space_id": {
          "$ref": "#/$defs/stable_id"
        },
        "knowledge_base": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_basis_item"
          }
        },
        "existing_artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifact_ref_id",
              "name",
              "relationship_to_project"
            ],
            "properties": {
              "artifact_ref_id": {
                "$ref": "#/$defs/stable_id"
              },
              "name": {
                "$ref": "#/$defs/non_empty_string"
              },
              "artifact_type": {
                "$ref": "#/$defs/artifact_type"
              },
              "relationship_to_project": {
                "$ref": "#/$defs/non_empty_string"
              },
              "limitations": {
                "type": "string"
              }
            }
          }
        },
        "design_constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "alternatives_considered": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "solution_grounding_summary": {
          "type": "string"
        }
      }
    },
    "artifact_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "artifact_name",
        "artifact_types",
        "abstraction_level",
        "artifact_materiality",
        "artifact_description",
        "artifact_boundary",
        "components",
        "make_plan",
        "use_plan"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/stable_id"
        },
        "artifact_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "artifact_types": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/artifact_type"
          }
        },
        "abstraction_level": {
          "$ref": "#/$defs/abstraction_level"
        },
        "artifact_materiality": {
          "$ref": "#/$defs/artifact_materiality"
        },
        "artifact_description": {
          "$ref": "#/$defs/non_empty_string"
        },
        "artifact_boundary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "artifact_novelty_claim": {
          "type": "string"
        },
        "artifact_reusability_claim": {
          "type": "string"
        },
        "components": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact_component"
          }
        },
        "make_plan": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/plan_step"
